---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('work');
const sorted = projects.sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));
---

<BaseLayout title="Work" description="Projects and things I've built.">
  <div class="pt-32 pb-24 px-6">
    <div class="max-w-7xl mx-auto">
      <Badge tag="work" />
      <h1 class="font-display text-5xl md:text-7xl font-bold text-cream leading-tight mt-6 mb-16">
        Selected work.
      </h1>

      {sorted.length === 0 ? (
        <div class="border border-border p-16 text-center">
          <p class="font-mono text-sm text-muted">Projects coming soon.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
          {sorted.map((project) => (
            <article class="bg-ink p-8 flex flex-col gap-4 group">
              {project.data.image && (
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="w-full aspect-video object-cover mb-2"
                />
              )}
              <div class="flex flex-wrap gap-2">
                {project.data.tags.map((tag) => <Badge tag={tag} />)}
              </div>
              <h2 class="font-display text-2xl font-bold text-cream group-hover:text-violet transition-colors">
                {project.data.title}
              </h2>
              <p class="text-muted text-sm leading-relaxed flex-1">{project.data.description}</p>
              {project.data.url && (
                <a
                  href={project.data.url}
                  class="font-mono text-xs text-violet hover:text-violet/70 transition-colors mt-auto"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  view project →
                </a>
              )}
            </article>
          ))}
        </div>
      )}

      <div class="mt-16 border-t border-border pt-12 text-center">
        <p class="text-muted text-sm mb-6">Have a project in mind?</p>
        <Button href="/contact">Work together →</Button>
      </div>
    </div>
  </div>
</BaseLayout>
