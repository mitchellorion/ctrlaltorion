---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';

// Public Web3Forms access key. Set PUBLIC_WEB3FORMS_KEY in Vercel env,
// or replace the fallback string below with your key from web3forms.com.
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '3e05cf6b-15a7-48c4-9ec8-14b0ea9116fc';
---

<BaseLayout
  title="Contact"
  description="Have a project in mind? Let's talk."
>
  <div class="pt-32 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <Badge tag="contact" />
      <h1 class="font-display text-5xl md:text-7xl font-bold text-cream leading-tight mt-6 mb-4">
        Let's build<br />something.
      </h1>
      <p class="text-muted mb-12 max-w-md leading-relaxed">
        Have a project, an idea, or a tech problem you can't seem to solve?
        Tell me what's going on. I'll get back to you within 24 hours.
      </p>

      <form
        id="contact-form"
        class="space-y-6"
        method="POST"
        action="https://api.web3forms.com/submit"
      >
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="New message from ctrlaltorion.com" />
        <input type="hidden" name="from_name" value="ctrl + alt + orion" />
        <!-- Honeypot: bots fill this, humans never see it -->
        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
        />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="name" class="font-mono text-xs text-muted">name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Your name"
              class="bg-surface border border-border text-cream placeholder:text-muted/40 px-4 py-3 font-sans text-sm focus:outline-none focus:border-violet transition-colors"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="email" class="font-mono text-xs text-muted">email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="you@example.com"
              class="bg-surface border border-border text-cream placeholder:text-muted/40 px-4 py-3 font-sans text-sm focus:outline-none focus:border-violet transition-colors"
            />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="subject" class="font-mono text-xs text-muted">what do you need?</label>
          <select
            id="subject"
            name="need"
            class="bg-surface border border-border text-cream px-4 py-3 font-mono text-sm focus:outline-none focus:border-violet transition-colors"
          >
            <option value="app">Build an app</option>
            <option value="web">Build a website</option>
            <option value="automation">Set up automations</option>
            <option value="consult">Just need advice</option>
            <option value="other">Something else</option>
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="font-mono text-xs text-muted">tell me more</label>
          <textarea
            id="message"
            name="message"
            rows={6}
            required
            placeholder="What are you trying to build or solve? The more detail, the better."
            class="bg-surface border border-border text-cream placeholder:text-muted/40 px-4 py-3 font-sans text-sm focus:outline-none focus:border-violet transition-colors resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="font-mono text-sm bg-cream text-ink px-8 py-3 hover:bg-cream/80 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send it →
        </button>
      </form>

      <p
        id="form-status"
        class="mt-6 font-mono text-sm"
        role="status"
        aria-live="polite"
      ></p>
    </div>
  </div>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');

    if (form && status) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]');
        const label = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Sending…';
        status.textContent = '';
        status.className = 'mt-6 font-mono text-sm';

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          const data = await res.json();

          if (res.ok && data.success) {
            form.reset();
            status.textContent = "Got it — I'll get back to you within 24 hours.";
            status.className = 'mt-6 font-mono text-sm text-violet';
          } else {
            status.textContent =
              (data && data.message) ||
              'Something went wrong. Email me directly at mitchell@ctrlaltorion.com.';
            status.className = 'mt-6 font-mono text-sm text-red-400';
          }
        } catch (err) {
          status.textContent =
            'Network error. Email me directly at mitchell@ctrlaltorion.com.';
          status.className = 'mt-6 font-mono text-sm text-red-400';
        } finally {
          btn.disabled = false;
          btn.textContent = label;
        }
      });
    }
  </script>
</BaseLayout>
