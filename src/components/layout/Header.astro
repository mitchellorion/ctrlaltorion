---
const navLinks = [
  { href: '/articles', label: 'articles' },
  { href: '/work', label: 'work' },
  { href: '/about', label: 'about' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-ink/90 backdrop-blur-sm border-b border-border">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-mono text-sm text-cream hover:text-violet transition-colors">
      [ctrl + alt + orion]
    </a>

    <div class="flex items-center gap-8">
      <ul class="hidden md:flex items-center gap-8">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'font-mono text-sm transition-colors',
                currentPath.startsWith(href) ? 'text-violet' : 'text-muted hover:text-cream',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href="/contact"
        class="font-mono text-sm bg-violet text-cream px-4 py-2 hover:bg-violet/80 transition-colors"
      >
        hire me →
      </a>
    </div>
  </nav>
</header>
