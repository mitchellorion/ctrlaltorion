---
import { getCollection } from 'astro:content';
import Badge from '@/components/ui/Badge.astro';

const allWork = await getCollection('work');
const featured = allWork.filter((p) => p.data.featured).slice(0, 3);
---

{featured.length > 0 && (
  <section id="work" class="bg-ink py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-16">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-cream">
          Selected work.
        </h2>
        <a href="/work" class="font-mono text-sm text-muted hover:text-cream transition-colors hidden md:block">
          all projects →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
        {featured.map((project) => (
          <article class="bg-ink p-8 flex flex-col gap-4 group">
            <div class="flex flex-wrap gap-2">
              {project.data.tags.slice(0, 2).map((tag) => (
                <Badge tag={tag} />
              ))}
            </div>
            <h3 class="font-display text-2xl font-bold text-cream group-hover:text-violet transition-colors">
              {project.data.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed">{project.data.description}</p>
            {project.data.url && (
              <a
                href={project.data.url}
                class="font-mono text-xs text-violet hover:text-violet/70 transition-colors mt-auto"
                target="_blank"
                rel="noopener noreferrer"
              >
                view project →
              </a>
            )}
          </article>
        ))}
      </div>

      <a href="/work" class="font-mono text-sm text-muted hover:text-cream transition-colors mt-8 inline-block md:hidden">
        all projects →
      </a>
    </div>
  </section>
)}
