---
import Button from '@/components/ui/Button.astro';
---

<section class="min-h-screen bg-ink flex flex-col pt-16">
  <div class="max-w-7xl mx-auto w-full px-6 flex flex-col lg:flex-row items-center gap-12 lg:gap-0 flex-1 py-20 lg:py-0">

    <div class="flex-1 flex flex-col justify-center lg:pr-16">
      <p class="font-mono text-xs text-muted mb-6 tracking-widest uppercase">ctrl + alt + orion</p>

      <h1 class="font-display text-6xl md:text-7xl xl:text-[6.5rem] font-bold text-cream leading-[0.88] tracking-tight">
        I build<br />
        the tech<br />
        you need.
      </h1>

      <p class="font-mono text-muted text-sm mt-8 max-w-sm leading-relaxed">
        Apps · Websites · Automations · Whatever —<br />
        if it's tech, I can do it.
      </p>

      <div class="flex flex-wrap gap-4 mt-10">
        <Button href="/contact">Work together →</Button>
        <Button href="/articles" variant="outline">Read the articles →</Button>
      </div>

      <div class="border-t border-border mt-14 pt-6 flex gap-8">
        <div>
          <p class="font-mono text-xs text-muted">⌃ consulting</p>
        </div>
        <div>
          <p class="font-mono text-xs text-muted">⌥ building</p>
        </div>
        <div>
          <p class="font-mono text-xs text-muted">⌘ shipping</p>
        </div>
      </div>
    </div>

    <div class="lg:w-[480px] xl:w-[560px] shrink-0 flex items-center justify-center">
      <img
        src="/keycaps.jpg"
        alt="ctrl alt orion keyboard keys"
        class="w-full max-w-md lg:max-w-none rounded-2xl"
        loading="eager"
      />
    </div>

  </div>
</section>
