---
import Button from '@/components/ui/Button.astro';
---

<section class="relative min-h-screen bg-ink overflow-hidden flex flex-col pt-16">

  <!-- Floating keycap images — decorative layer -->
  <!--
    Spread across three bands so the keys never cram together:
    - mobile: ctrl peeks top-right, alt peeks mid-right, orion centered below the CTAs
    - desktop: a loose triangle across the right side (ctrl center-upper, alt far-right, orion center-lower)
  -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <!-- ctrl: top band (upper center-right on desktop) -->
    <img
      src="/key-ctrl.png"
      alt=""
      class="absolute rotate-[-8deg] opacity-90
             w-28 top-[5%] right-[-8%]
             sm:w-36 sm:right-[0%]
             md:w-48 md:top-[12%] md:right-[32%]
             lg:w-52"
    />
    <!-- alt: middle band (far right on desktop) -->
    <img
      src="/key-alt.png"
      alt=""
      class="absolute rotate-[6deg] opacity-80
             w-24 top-[45%] right-[-10%]
             sm:w-32 sm:right-[-2%]
             md:w-44 md:top-[48%] md:right-[8%]
             lg:w-48"
    />
    <!-- orion: bottom band (centered below CTAs on mobile, lower center-right on desktop) -->
    <img
      src="/key-orion.png"
      alt=""
      class="absolute rotate-[-3deg] opacity-95
             w-40 bottom-[7%] left-1/2 -translate-x-1/2
             sm:w-44
             md:w-64 md:bottom-[8%] md:left-auto md:right-[24%] md:translate-x-0
             lg:w-72"
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto w-full px-6 flex flex-col justify-start md:justify-center flex-1 py-20">

    <p class="font-mono text-xs text-muted mb-8 tracking-widest uppercase">
      ctrl + alt + orion
    </p>

    <h1 class="font-display font-bold text-cream leading-[0.88] tracking-tight"
        style="font-size: clamp(3.5rem, 9vw, 9rem);">
      I build<br />
      the tech<br />
      you need.
    </h1>

    <p class="font-mono text-muted text-sm mt-8 max-w-xs leading-relaxed">
      Apps · Websites · Automations · Whatever —<br />
      if it's tech, I can do it.
    </p>

    <div class="flex flex-wrap gap-4 mt-10">
      <Button href="/contact">Work together →</Button>
      <Button href="/articles" variant="outline">Read the articles →</Button>
    </div>

  </div>

  <!-- Bottom rule -->
  <div class="relative z-10 border-t border-border">
    <div class="max-w-7xl mx-auto px-6 py-5 flex gap-8">
      <p class="font-mono text-xs text-muted">⌃ consulting</p>
      <p class="font-mono text-xs text-muted">⌥ building</p>
      <p class="font-mono text-xs text-muted">⌘ shipping</p>
    </div>
  </div>

</section>
