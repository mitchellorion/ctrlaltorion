---
import { getCollection } from 'astro:content';
import Badge from '@/components/ui/Badge.astro';

const allArticles = await getCollection('articles');
const latest = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

{latest.length > 0 && (
  <section class="bg-surface border-t border-border py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-16">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-cream">
          From the archive.
        </h2>
        <a href="/articles" class="font-mono text-sm text-muted hover:text-cream transition-colors hidden md:block">
          all articles →
        </a>
      </div>

      <div class="flex flex-col divide-y divide-border">
        {latest.map((article) => (
          <a
            href={`/articles/${article.slug}`}
            class="group py-8 flex flex-col md:flex-row md:items-center gap-4 md:gap-8 hover:bg-ink/30 -mx-6 px-6 transition-colors"
          >
            <div class="flex flex-wrap gap-2 md:w-48 shrink-0">
              {article.data.tags.slice(0, 1).map((tag) => (
                <Badge tag={tag} />
              ))}
            </div>

            <div class="flex-1">
              <h3 class="font-display text-xl md:text-2xl font-bold text-cream group-hover:text-violet transition-colors">
                {article.data.title}
              </h3>
              <p class="text-muted text-sm mt-1 leading-relaxed line-clamp-2">
                {article.data.description}
              </p>
            </div>

            <time
              class="font-mono text-xs text-muted shrink-0"
              datetime={article.data.pubDate.toISOString()}
            >
              {new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(article.data.pubDate)}
            </time>
          </a>
        ))}
      </div>

      <a href="/articles" class="font-mono text-sm text-muted hover:text-cream transition-colors mt-8 inline-block md:hidden">
        all articles →
      </a>
    </div>
  </section>
)}
