---
import Badge from '@/components/ui/Badge.astro';
const services = [
  {
    tag: 'apps',
    title: 'App Development',
    description: 'Web apps, mobile apps, internal tools. From idea to shipped, end to end.',
  },
  {
    tag: 'web',
    title: 'Websites',
    description: 'Marketing sites, portfolios, landing pages. Fast, clean, and actually converts.',
  },
  {
    tag: 'automation',
    title: 'Automations',
    description: 'Workflows, integrations, data pipelines. Stop doing manually what code can handle.',
  },
  {
    tag: 'whatever',
    title: 'Whatever You Need',
    description: 'APIs, scrapers, scripts, dashboards. If it runs on a computer, I can build it.',
  },
];
---

<section id="services" class="bg-surface border-y border-border py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <h2 class="font-display text-4xl md:text-5xl font-bold text-cream mb-16">
      What I build.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-border">
      {services.map(({ tag, title, description }) => (
        <div class="bg-surface p-8 flex flex-col gap-4">
          <Badge tag={tag} />
          <h3 class="font-display text-xl font-bold text-cream">{title}</h3>
          <p class="text-muted text-sm leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
