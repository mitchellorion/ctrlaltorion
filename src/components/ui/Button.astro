---
interface Props {
  href: string;
  variant?: 'primary' | 'outline';
}

const { href, variant = 'primary' } = Astro.props;
---

<a
  href={href}
  class:list={[
    'font-sans font-medium text-sm px-6 py-3 inline-block transition-all rounded-sm',
    variant === 'primary' && 'bg-cream text-ink hover:bg-white',
    variant === 'outline' && 'border border-border text-cream hover:border-cream/60 hover:bg-cream/5',
  ]}
>
  <slot />
</a>
