---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
const label = `[ctrl + alt + ${tag}]`;
---

{href ? (
  <a
    href={href}
    class="font-mono text-xs text-violet border border-violet/40 px-2 py-1 hover:bg-violet/10 transition-colors inline-block"
  >
    {label}
  </a>
) : (
  <span class="font-mono text-xs text-violet border border-violet/40 px-2 py-1 inline-block">
    {label}
  </span>
)}
