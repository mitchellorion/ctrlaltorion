---
interface Props {
  variant: 'sidebar' | 'footer' | 'inline';
  slot?: string;
}

const { variant, slot: adSlot } = Astro.props;

const sizes = {
  sidebar: 'w-full min-h-[250px]',
  footer: 'w-full min-h-[90px] mt-12',
  inline: 'w-full min-h-[90px] my-8',
};

const formats = {
  sidebar: 'rectangle',
  footer: 'horizontal',
  inline: 'fluid',
};
---

<div class:list={['ad-slot overflow-hidden', sizes[variant]]}>
  {adSlot ? (
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-1946277948152462"
      data-ad-slot={adSlot}
      data-ad-format={formats[variant]}
      data-full-width-responsive="true"
    />
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  ) : (
    <div class="w-full h-full border border-border/30 flex items-center justify-center min-h-[inherit]">
      <span class="font-mono text-xs text-muted/30">ad · add slot id</span>
    </div>
  )}
</div>
